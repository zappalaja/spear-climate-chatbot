# Containerfile for SPEAR Climate Chatbot (Streamlit App Only)
# Designed to run in a pod with the SPEAR MCP server container
# Default LLM: Gemini (Ollama disabled for container deployment)

FROM python:3.13-slim

# Set working directory
WORKDIR /app

# Install system dependencies including curl for health check
RUN apt-get update && apt-get install -y \
    gcc \
    g++ \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements first for better layer caching
COPY requirements.txt .

# Install Python dependencies
RUN pip install --no-cache-dir -r requirements.txt

# Copy application code (excluding .env - API keys passed at runtime)
COPY *.py *.yaml ./
COPY pages/ ./pages/

# Create logs directory
RUN mkdir -p chat_logs

# Set environment variables for pod communication
ENV MCP_SERVER_HOST=spear-mcp-server
ENV MCP_SERVER_PORT=8000

# API keys must be provided at runtime via:
#   -e GEMINI_API_KEY=your_key
#   -e ANTHROPIC_API_KEY=your_key
# Or via --env-file with a secure .env file (not included in image)

# RAG configuration (can be overridden at runtime)
ENV RAG_ENABLED=true
ENV RAG_TOP_K=2
ENV RAG_API_URL=http://spear-rag-server:8002

# Expose Streamlit port
EXPOSE 8501

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:8501/_stcore/health || exit 1

# Run Streamlit app
CMD ["streamlit", "run", "SPEAR_Earth_System_Data_Assistant.py", "--server.port=8501", "--server.address=0.0.0.0", "--server.headless=true"]
