# SPEAR Climate Chatbot - Environment Variables
# Copy this file to .env and fill in your API keys
# NEVER commit .env to version control!

# Auth — set to true to require login (see users.yaml and manage_users.py)
AUTH_ENABLED=false
# Restore each user's last conversation when they log back in
PERSIST_CONVERSATIONS=false

# Logging settings
# Set to false to disable chat history logging to disk
LOGGING_ENABLED=true
# Directory for chat history logs (relative to chatbot/ or absolute path)
CHAT_LOG_DIR=chat_logs

# Required: At least one LLM API key
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# MCP Server (adjust based on deployment)
MCP_SERVER_URL=http://localhost:8000
# MCP_SERVER_DIR is only needed if MCP_SERVER_URL is unset (stdio fallback mode)
# MCP_SERVER_DIR=/absolute/path/to/mcp-server

# RAG Service
RAG_ENABLED=true
RAG_TOP_K=2
RAG_API_URL=http://localhost:8002
